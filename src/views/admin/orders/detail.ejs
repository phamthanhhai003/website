<%- include('../../partials/admin-top') %>
<% const statusColors = {pending:'warning',confirmed:'info',processing:'primary',shipping:'primary',completed:'success',cancelled:'danger'};
   const statusLabels = {pending:'Chờ xác nhận',confirmed:'Đã xác nhận',processing:'Đang chuẩn bị',shipping:'Đang giao',completed:'Hoàn thành',cancelled:'Đã hủy'};
   const TRANSITIONS = {pending:['confirmed','cancelled'],confirmed:['processing','cancelled'],processing:['shipping','cancelled'],shipping:['completed','cancelled'],completed:[],cancelled:[]};
%>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0">#<%= order.order_code %></h4>
  <a href="/admin/orders" class="btn btn-outline-secondary btn-sm">← Quay lại</a>
</div>

<div class="row g-3">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-bold">Sản phẩm</div>
      <div class="card-body p-0">
        <table class="table table-sm admin-table mb-0">
          <thead><tr><th>Sản phẩm</th><th>Đơn giá</th><th>SL</th><th>Thành tiền</th></tr></thead>
          <tbody>
            <% items.forEach(item => { %>
              <tr>
                <td><div class="small fw-medium"><%= item.product_name %></div></td>
                <td class="small"><%= Number(item.price).toLocaleString('vi-VN') %>đ</td>
                <td><%= item.quantity %></td>
                <td class="small fw-medium"><%= Number(item.total_price).toLocaleString('vi-VN') %>đ</td>
              </tr>
            <% }); %>
          </tbody>
          <tfoot>
            <tr class="fw-bold">
              <td colspan="3">Tổng cộng</td>
              <td class="text-danger"><%= Number(order.total_amount).toLocaleString('vi-VN') %>đ</td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <% if (TRANSITIONS[order.order_status] && TRANSITIONS[order.order_status].length > 0) { %>
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <h6 class="fw-bold mb-3">Cập nhật trạng thái</h6>
          <form action="/admin/orders/<%= order.id %>/status" method="POST" class="d-flex gap-2">
            <select name="order_status" class="form-select form-select-sm">
              <% TRANSITIONS[order.order_status].forEach(s => { %>
                <option value="<%= s %>"><%= statusLabels[s] %></option>
              <% }); %>
            </select>
            <button type="submit" class="btn btn-primary btn-sm">Cập nhật</button>
          </form>
        </div>
      </div>
    <% } %>

    <% if (order.payment_method === 'bank_transfer' && order.payment_status !== 'paid') { %>
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="fw-bold text-success mb-2">Xác nhận thanh toán chuyển khoản</h6>
          <form action="/admin/orders/<%= order.id %>/confirm-payment" method="POST" class="d-flex gap-2">
            <input type="text" name="transaction_code" class="form-control form-control-sm"
                   placeholder="Mã giao dịch ngân hàng">
            <button type="submit" class="btn btn-success btn-sm">Xác nhận</button>
          </form>
        </div>
      </div>
    <% } %>
  </div>

  <div class="col-lg-4">
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body">
        <h6 class="fw-bold mb-2">Thông tin đơn hàng</h6>
        <div class="mb-1">Trạng thái: <span class="badge bg-<%= statusColors[order.order_status] || 'secondary' %>"><%= statusLabels[order.order_status] %></span></div>
        <div class="mb-1 small text-muted">Ngày đặt: <%= new Date(order.created_at).toLocaleString('vi-VN') %></div>
        <div class="mb-1 small">PP thanh toán: <strong><%= order.payment_method ? order.payment_method.toUpperCase() : '' %></strong></div>
        <% if (payment && payment.paid_at) { %>
          <div class="small text-success">Đã thanh toán: <%= new Date(payment.paid_at).toLocaleString('vi-VN') %></div>
        <% } %>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <h6 class="fw-bold mb-2">Giao hàng</h6>
        <p class="mb-1"><strong><%= order.shipping_name %></strong></p>
        <p class="mb-1 small"><%= order.shipping_phone %></p>
        <p class="mb-0 small text-muted"><%= order.shipping_address %></p>
        <% if (order.note) { %>
          <p class="mt-2 mb-0 small text-muted">Ghi chú: <%= order.note %></p>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../../partials/admin-bot') %>
