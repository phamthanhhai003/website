<%- include('../../partials/admin-top') %>
<h4 class="fw-bold mb-4">Quản lý người dùng</h4>

<form class="row g-2 mb-3" method="GET">
  <div class="col-md-4">
    <input type="text" name="keyword" class="form-control form-control-sm"
           placeholder="Tìm tên, email..." value="<%= keyword || '' %>">
  </div>
  <div class="col-auto"><button type="submit" class="btn btn-primary btn-sm">Tìm</button></div>
</form>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <table class="table table-hover admin-table mb-0">
      <thead>
        <tr><th>Họ tên</th><th>Email</th><th>Phone</th><th>Vai trò</th><th>Trạng thái</th><th>Ngày tạo</th><th></th></tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
          <tr>
            <td class="fw-medium small"><%= u.full_name %></td>
            <td class="small"><%= u.email %></td>
            <td class="small"><%= u.phone || '—' %></td>
            <td><span class="badge <%= u.role === 'admin' ? 'bg-danger' : 'bg-primary' %>"><%= u.role %></span></td>
            <td><span class="badge <%= u.status === 'active' ? 'bg-success' : 'bg-secondary' %>"><%= u.status %></span></td>
            <td class="small text-muted"><%= new Date(u.created_at).toLocaleDateString('vi-VN') %></td>
            <td>
              <% if (u.role !== 'admin') { %>
                <form action="/admin/users/<%= u.id %>/status" method="POST" class="d-inline">
                  <input type="hidden" name="status" value="<%= u.status === 'active' ? 'blocked' : 'active' %>">
                  <button type="submit" class="btn btn-sm <%= u.status === 'active' ? 'btn-outline-danger' : 'btn-outline-success' %>">
                    <%= u.status === 'active' ? 'Khoá' : 'Mở khoá' %>
                  </button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../../partials/admin-bot') %>
