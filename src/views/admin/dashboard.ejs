<%- include('../partials/admin-top') %>
<h4 class="mb-4 fw-bold">Dashboard</h4>

<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm stat-card blue">
      <div class="card-body">
        <div class="text-muted small">Tổng doanh thu</div>
        <div class="fs-4 fw-bold text-primary mt-1"><%= Number(totalRevenue).toLocaleString('vi-VN') %>đ</div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm stat-card green">
      <div class="card-body">
        <div class="text-muted small">Đơn hoàn thành</div>
        <div class="fs-4 fw-bold text-success mt-1"><%= orderByStatus.completed || 0 %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm stat-card orange">
      <div class="card-body">
        <div class="text-muted small">Đơn chờ xử lý</div>
        <div class="fs-4 fw-bold text-warning mt-1"><%= (orderByStatus.pending || 0) + (orderByStatus.confirmed || 0) %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm stat-card red">
      <div class="card-body">
        <div class="text-muted small">SP sắp hết hàng</div>
        <div class="fs-4 fw-bold text-danger mt-1"><%= lowStock.length %></div>
      </div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white d-flex align-items-center justify-content-between">
    <span class="fw-bold"><i class="bi bi-bar-chart-line me-2 text-primary"></i>Doanh thu 12 tháng gần nhất</span>
    <small class="text-muted">Đơn hoàn thành & đã thanh toán</small>
  </div>
  <div class="card-body">
    <canvas id="revenueChart" height="90"></canvas>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white fw-bold">Đơn hàng gần đây</div>
      <div class="card-body p-0">
        <table class="table table-sm admin-table mb-0">
          <thead><tr><th>Mã đơn</th><th>Tổng tiền</th><th>Trạng thái</th><th>Ngày</th></tr></thead>
          <tbody>
            <% const statusColors = {pending:'warning',confirmed:'info',processing:'primary',shipping:'primary',completed:'success',cancelled:'danger'};
               const statusLabels = {pending:'Chờ XN',confirmed:'Đã XN',processing:'Chuẩn bị',shipping:'Đang giao',completed:'Hoàn thành',cancelled:'Đã hủy'};
            %>
            <% recentOrders.forEach(o => { %>
              <tr>
                <td><a href="/admin/orders/<%= o.id || '' %>" class="text-decoration-none"><%= o.order_code %></a></td>
                <td><%= Number(o.total_amount).toLocaleString('vi-VN') %>đ</td>
                <td><span class="badge bg-<%= statusColors[o.order_status] || 'secondary' %>"><%= statusLabels[o.order_status] || o.order_status %></span></td>
                <td class="small text-muted"><%= new Date(o.created_at).toLocaleDateString('vi-VN') %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white fw-bold text-danger">
        <i class="bi bi-exclamation-triangle me-1"></i>Sản phẩm sắp hết hàng
      </div>
      <div class="card-body p-0">
        <% if (lowStock.length === 0) { %>
          <p class="text-muted p-3 mb-0">Không có sản phẩm sắp hết hàng</p>
        <% } else { %>
          <table class="table table-sm admin-table mb-0">
            <thead><tr><th>Sản phẩm</th><th>Tồn kho</th></tr></thead>
            <tbody>
              <% lowStock.forEach(p => { %>
                <tr>
                  <td class="small"><%= p.name %></td>
                  <td><span class="badge <%= p.stock_quantity === 0 ? 'bg-danger' : 'bg-warning text-dark' %>"><%= p.stock_quantity %></span></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>

    <div class="card border-0 shadow-sm mt-3">
      <div class="card-header bg-white fw-bold">Top sản phẩm bán chạy</div>
      <div class="card-body p-0">
        <% if (topProducts.length === 0) { %>
          <p class="text-muted p-3 mb-0">Chưa có dữ liệu</p>
        <% } else { %>
          <table class="table table-sm admin-table mb-0">
            <thead><tr><th>Sản phẩm</th><th>Đã bán</th></tr></thead>
            <tbody>
              <% topProducts.forEach(p => { %>
                <tr><td class="small"><%= p.name %></td><td><%= p.total_sold %></td></tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function() {
  const raw = <%- JSON.stringify(revenueByMonth) %>;

  // Fill all 12 months kể cả tháng không có doanh thu
  const months = [];
  const revenues = [];
  const orders = [];
  const now = new Date();
  for (let i = 11; i >= 0; i--) {
    const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    const key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    const label = 'T' + (d.getMonth() + 1) + '/' + d.getFullYear();
    const found = raw.find(r => r.month === key);
    months.push(label);
    revenues.push(found ? Number(found.revenue) : 0);
    orders.push(found ? Number(found.order_count) : 0);
  }

  const ctx = document.getElementById('revenueChart').getContext('2d');
  const grad = ctx.createLinearGradient(0, 0, 0, 320);
  grad.addColorStop(0, 'rgba(13,110,253,0.25)');
  grad.addColorStop(1, 'rgba(13,110,253,0)');

  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: months,
      datasets: [
        {
          type: 'line',
          label: 'Doanh thu (đ)',
          data: revenues,
          borderColor: '#0d6efd',
          backgroundColor: grad,
          borderWidth: 2.5,
          pointBackgroundColor: '#0d6efd',
          pointRadius: 4,
          pointHoverRadius: 6,
          fill: true,
          tension: 0.4,
          yAxisID: 'y'
        },
        {
          type: 'bar',
          label: 'Số đơn',
          data: orders,
          backgroundColor: 'rgba(25,135,84,0.15)',
          borderColor: 'rgba(25,135,84,0.6)',
          borderWidth: 1.5,
          borderRadius: 6,
          yAxisID: 'y1'
        }
      ]
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { position: 'top', labels: { usePointStyle: true, padding: 20, font: { size: 12 } } },
        tooltip: {
          callbacks: {
            label: ctx => {
              if (ctx.datasetIndex === 0) return ' Doanh thu: ' + Number(ctx.raw).toLocaleString('vi-VN') + 'đ';
              return ' Số đơn: ' + ctx.raw;
            }
          }
        }
      },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 11 } } },
        y: {
          position: 'left',
          grid: { color: 'rgba(0,0,0,0.05)' },
          ticks: {
            font: { size: 11 },
            callback: v => v >= 1e6 ? (v/1e6).toFixed(1) + 'M' : v >= 1e3 ? (v/1e3).toFixed(0) + 'K' : v
          }
        },
        y1: {
          position: 'right',
          grid: { drawOnChartArea: false },
          ticks: { font: { size: 11 }, stepSize: 1 }
        }
      }
    }
  });
})();
</script>
<%- include('../partials/admin-bot') %>
