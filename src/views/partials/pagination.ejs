<% if (typeof pagination !== 'undefined' && pagination.totalPages > 1) { %>
<nav aria-label="Phân trang" class="mt-4">
  <ul class="pagination justify-content-center">
    <% if (pagination.hasPrev) { %>
      <li class="page-item">
        <a class="page-link" href="?<%= queryString %>&page=<%= pagination.page - 1 %>">
          <i class="bi bi-chevron-left"></i>
        </a>
      </li>
    <% } %>
    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
      <% if (i === pagination.page) { %>
        <li class="page-item active"><span class="page-link"><%= i %></span></li>
      <% } else if (i === 1 || i === pagination.totalPages || Math.abs(i - pagination.page) <= 2) { %>
        <li class="page-item">
          <a class="page-link" href="?<%= queryString %>&page=<%= i %>"><%= i %></a>
        </li>
      <% } else if (Math.abs(i - pagination.page) === 3) { %>
        <li class="page-item disabled"><span class="page-link">...</span></li>
      <% } %>
    <% } %>
    <% if (pagination.hasNext) { %>
      <li class="page-item">
        <a class="page-link" href="?<%= queryString %>&page=<%= pagination.page + 1 %>">
          <i class="bi bi-chevron-right"></i>
        </a>
      </li>
    <% } %>
  </ul>
</nav>
<% } %>
