<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">
      <i class="bi bi-lightning-charge-fill text-warning"></i> ElectroShop
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarMain">
      <!-- Search -->
      <form class="d-flex mx-auto" action="/products" method="GET" style="width:40%">
        <input class="form-control me-2" type="search" name="q" placeholder="Tìm kiếm sản phẩm..."
               value="<%= typeof query !== 'undefined' ? query : '' %>">
        <button class="btn btn-warning" type="submit">
          <i class="bi bi-search"></i>
        </button>
      </form>
      <!-- Nav links -->
      <ul class="navbar-nav ms-auto align-items-center gap-2">
        <li class="nav-item">
          <a class="nav-link" href="/products">Sản phẩm</a>
        </li>
        <li class="nav-item">
          <a class="nav-link position-relative" href="/cart">
            <i class="bi bi-cart3 fs-5"></i>
            <% if (cartCount > 0) { %>
              <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                <%= cartCount %>
              </span>
            <% } %>
          </a>
        </li>
        <% if (user) { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= user.full_name %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-2"></i>Tài khoản</a></li>
              <li><a class="dropdown-item" href="/orders"><i class="bi bi-bag me-2"></i>Đơn hàng</a></li>
              <li><a class="dropdown-item" href="/warranty"><i class="bi bi-shield-check me-2"></i>Bảo hành</a></li>
              <% if (user.role === 'admin') { %>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-primary" href="/admin"><i class="bi bi-gear me-2"></i>Quản trị</a></li>
              <% } %>
              <li><hr class="dropdown-divider"></li>
              <li>
                <form action="/logout" method="POST" class="d-inline">
                  <button type="submit" class="dropdown-item text-danger">
                    <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                  </button>
                </form>
              </li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/login">Đăng nhập</a>
          </li>
          <li class="nav-item">
            <a class="btn btn-warning btn-sm" href="/register">Đăng ký</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
