<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title + ' | Admin ElectroShop' : 'Admin ElectroShop' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body>
  <div class="d-flex" id="wrapper">
    <div class="bg-dark text-white" id="sidebar-wrapper" style="min-width:220px;min-height:100vh">
      <div class="sidebar-heading p-3 fw-bold fs-5 border-bottom border-secondary">
        <i class="bi bi-lightning-charge-fill text-warning"></i> ElectroShop
      </div>
      <div class="list-group list-group-flush">
        <a href="/admin" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </a>
        <a href="/admin/products" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="bi bi-box-seam me-2"></i>Sản phẩm
        </a>
        <a href="/admin/categories" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="bi bi-tags me-2"></i>Danh mục
        </a>
        <a href="/admin/orders" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="bi bi-bag-check me-2"></i>Đơn hàng
        </a>
        <a href="/admin/users" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="bi bi-people me-2"></i>Người dùng
        </a>
        <a href="/admin/reviews" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="bi bi-star me-2"></i>Đánh giá
        </a>
        <a href="/admin/warranty" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="bi bi-shield-check me-2"></i>Bảo hành
        </a>
        <hr class="border-secondary my-1">
        <a href="/" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="bi bi-house me-2"></i>Về trang chủ
        </a>
        <a href="/logout" class="list-group-item list-group-item-action bg-dark text-danger border-0 py-3">
          <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
        </a>
      </div>
    </div>
    <div id="page-content-wrapper" class="flex-grow-1">
      <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom px-3">
        <span class="navbar-brand mb-0 h1 text-muted fs-6">
          Xin chào, <%= user ? user.full_name : 'Admin' %>
        </span>
      </nav>
      <div class="p-4">
        <%- include('./flash') %>
