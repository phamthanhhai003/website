<div class="card product-card h-100 border-0 shadow-sm">
  <div class="position-relative">
    <a href="/products/<%= product.slug %>">
      <img src="<%= product.main_image || '/images/no-image.png' %>"
           class="card-img-top" style="height:200px;object-fit:contain;padding:12px;background:#fff"
           alt="<%= product.name %>" loading="lazy"
           onerror="this.src='/images/no-image.png'">
    </a>
    <% if (product.sale_price) {
         const discount = Math.round((1 - product.sale_price / product.price) * 100); %>
      <span class="badge bg-danger position-absolute top-0 end-0 m-2">-<%= discount %>%</span>
    <% } %>
    <% if (product.stock_quantity === 0) { %>
      <div class="position-absolute bottom-0 start-0 end-0 bg-dark bg-opacity-60 text-white text-center py-1 small">
        Hết hàng
      </div>
    <% } %>
  </div>
  <div class="card-body d-flex flex-column pt-2">
    <small class="text-muted"><%= product.brand || '' %></small>
    <h6 class="card-title mt-1 mb-auto" style="font-size:0.9rem;line-height:1.3">
      <a href="/products/<%= product.slug %>" class="text-decoration-none text-dark stretched-link">
        <%= product.name %>
      </a>
    </h6>
    <div class="mt-2">
      <% if (product.avg_rating > 0) { %>
        <small class="text-warning">
          <% for(let i=1; i<=5; i++) { %>
            <i class="bi bi-star<%= i <= Math.round(product.avg_rating) ? '-fill' : '' %>"></i>
          <% } %>
          <span class="text-muted">(<%= product.review_count %>)</span>
        </small>
      <% } %>
      <div class="mt-1">
        <% if (product.sale_price) { %>
          <span class="fw-bold text-danger"><%= Number(product.sale_price).toLocaleString('vi-VN') %>đ</span>
          <del class="text-muted small ms-1"><%= Number(product.price).toLocaleString('vi-VN') %>đ</del>
        <% } else { %>
          <span class="fw-bold text-danger"><%= Number(product.price).toLocaleString('vi-VN') %>đ</span>
        <% } %>
      </div>
    </div>
  </div>
</div>
