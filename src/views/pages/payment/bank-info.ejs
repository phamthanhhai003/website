<%- include('../../partials/top') %>
<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center p-4">
        <i class="bi bi-bank2 fs-1 text-primary mb-3"></i>
        <h4 class="fw-bold">Hướng dẫn chuyển khoản</h4>
        <p class="text-muted">Đơn hàng <strong>#<%= order.order_code %></strong></p>

        <div class="card bg-light border-0 p-3 mb-4 text-start">
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Ngân hàng</span>
            <strong><%= bankName %></strong>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Số tài khoản</span>
            <strong class="fs-5 text-primary"><%= bankAccount %></strong>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Chủ tài khoản</span>
            <strong><%= accountName %></strong>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Số tiền</span>
            <strong class="text-danger fs-5"><%= Number(order.total_amount).toLocaleString('vi-VN') %>đ</strong>
          </div>
          <div class="d-flex justify-content-between">
            <span class="text-muted">Nội dung CK</span>
            <strong class="text-danger"><%= transferContent %></strong>
          </div>
        </div>

        <div class="alert alert-warning text-start">
          <i class="bi bi-exclamation-triangle me-2"></i>
          <strong>Lưu ý:</strong> Ghi đúng nội dung <strong><%= transferContent %></strong> để chúng tôi xác nhận tự động.
        </div>

        <a href="/orders/<%= order.order_code %>" class="btn btn-primary">
          <i class="bi bi-bag me-2"></i>Xem đơn hàng của tôi
        </a>
      </div>
    </div>
  </div>
</div>
<%- include('../../partials/bot') %>
