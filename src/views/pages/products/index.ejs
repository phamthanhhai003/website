<%- include('../../partials/top') %>
<div class="row">
  <div class="col-lg-3 mb-4">
    <form id="filter-form" action="/products" method="GET">
      <% if (filters.keyword) { %><input type="hidden" name="keyword" value="<%= filters.keyword %>"><% } %>
      <div class="card border-0 shadow-sm p-3">
        <h6 class="fw-bold mb-2">Danh mục</h6>
        <% categories.forEach(cat => { %>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="category"
                   value="<%= cat.slug %>" id="cat-<%= cat.id %>"
                   <%= typeof filters !== 'undefined' && filters.category === cat.slug ? 'checked' : '' %>
                   onchange="this.form.submit()">
            <label class="form-check-label small" for="cat-<%= cat.id %>"><%= cat.name %></label>
          </div>
        <% }); %>

        <hr class="my-2">
        <h6 class="fw-bold mb-2">Khoảng giá</h6>
        <div class="row g-1 mb-2">
          <div class="col">
            <input type="number" name="minPrice" class="form-control form-control-sm"
                   placeholder="Từ" value="<%= typeof filters !== 'undefined' ? (filters.minPrice || '') : '' %>">
          </div>
          <div class="col">
            <input type="number" name="maxPrice" class="form-control form-control-sm"
                   placeholder="Đến" value="<%= typeof filters !== 'undefined' ? (filters.maxPrice || '') : '' %>">
          </div>
        </div>

        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="onSale" value="1"
                 <%= typeof filters !== 'undefined' && filters.onSale === '1' ? 'checked' : '' %>
                 onchange="this.form.submit()">
          <label class="form-check-label small">Đang giảm giá</label>
        </div>
        <div class="form-check mb-2">
          <input class="form-check-input" type="checkbox" name="inStock" value="1"
                 <%= typeof filters !== 'undefined' && filters.inStock === '1' ? 'checked' : '' %>
                 onchange="this.form.submit()">
          <label class="form-check-label small">Còn hàng</label>
        </div>

        <button type="submit" class="btn btn-primary btn-sm w-100">Lọc</button>
        <a href="/products" class="btn btn-outline-secondary btn-sm w-100 mt-1">Xoá bộ lọc</a>
      </div>
    </form>
  </div>

  <div class="col-lg-9">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
      <h5 class="mb-0"><%= title %> <span class="badge bg-secondary fs-6"><%= pagination.totalItems %></span></h5>
      <select name="sort" form="filter-form" class="form-select form-select-sm w-auto"
              onchange="this.form.submit()">
        <option value="newest" <%= typeof filters !== 'undefined' && filters.sort === 'newest' ? 'selected' : '' %>>Mới nhất</option>
        <option value="price_asc" <%= typeof filters !== 'undefined' && filters.sort === 'price_asc' ? 'selected' : '' %>>Giá thấp → cao</option>
        <option value="price_desc" <%= typeof filters !== 'undefined' && filters.sort === 'price_desc' ? 'selected' : '' %>>Giá cao → thấp</option>
        <option value="rating" <%= typeof filters !== 'undefined' && filters.sort === 'rating' ? 'selected' : '' %>>Đánh giá cao</option>
      </select>
    </div>

    <% if (products.length === 0) { %>
      <div class="empty-state">
        <i class="bi bi-search"></i>
        <p class="mt-3">Không tìm thấy sản phẩm phù hợp</p>
        <a href="/products" class="btn btn-outline-primary">Xem tất cả</a>
      </div>
    <% } else { %>
      <div class="row row-cols-2 row-cols-md-3 g-3">
        <% products.forEach(product => { %>
          <div class="col"><%- include('../../partials/product-card', { product }) %></div>
        <% }); %>
      </div>
      <%- include('../../partials/pagination', { pagination, queryString: new URLSearchParams(Object.fromEntries(Object.entries(filters || {}).filter(([k]) => k !== 'page'))).toString() }) %>
    <% } %>
  </div>
</div>
<%- include('../../partials/bot') %>
