<%- include('../../partials/top') %>
<div class="row">
  <div class="col-md-5 mb-4">
    <div class="border rounded p-3 text-center bg-white">
      <img id="main-img"
           src="<%= product.images && product.images.length > 0 ? product.images[0].image_url : '/images/no-image.png' %>"
           class="img-fluid" style="max-height:400px;object-fit:contain"
           alt="<%= product.name %>"
           onerror="this.src='/images/no-image.png'">
    </div>
    <% if (product.images && product.images.length > 1) { %>
      <div class="d-flex gap-2 mt-2 flex-wrap">
        <% product.images.forEach(img => { %>
          <img src="<%= img.image_url %>" class="border rounded" style="width:70px;height:70px;object-fit:contain;cursor:pointer"
               onclick="document.getElementById('main-img').src='<%= img.image_url %>'"
               onerror="this.src='/images/no-image.png'">
        <% }); %>
      </div>
    <% } %>
  </div>

  <div class="col-md-7">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
        <li class="breadcrumb-item"><a href="/categories/<%= product.category_slug %>"><%= product.category_name %></a></li>
        <li class="breadcrumb-item active"><%= product.name %></li>
      </ol>
    </nav>

    <h4 class="fw-bold"><%= product.name %></h4>
    <p class="text-muted mb-1">Thương hiệu: <strong><%= product.brand || 'N/A' %></strong></p>

    <% if (product.avg_rating > 0) { %>
      <div class="mb-2">
        <span class="text-warning">
          <% for(let i=1; i<=5; i++) { %>
            <i class="bi bi-star<%= i <= Math.round(product.avg_rating) ? '-fill' : '' %>"></i>
          <% } %>
        </span>
        <span class="text-muted ms-1"><%= product.avg_rating %> (<%= product.review_count %> đánh giá)</span>
      </div>
    <% } %>

    <div class="mb-3">
      <% if (product.sale_price) { %>
        <span class="display-6 fw-bold text-danger"><%= Number(product.sale_price).toLocaleString('vi-VN') %>đ</span>
        <del class="text-muted ms-2 fs-5"><%= Number(product.price).toLocaleString('vi-VN') %>đ</del>
        <% const discount = Math.round((1 - product.sale_price / product.price) * 100); %>
        <span class="badge bg-danger ms-2">Tiết kiệm <%= discount %>%</span>
      <% } else { %>
        <span class="display-6 fw-bold text-danger"><%= Number(product.price).toLocaleString('vi-VN') %>đ</span>
      <% } %>
    </div>

    <% if (product.warranty_months > 0) { %>
      <p class="mb-2"><i class="bi bi-shield-check text-success me-1"></i>Bảo hành <%= product.warranty_months %> tháng chính hãng</p>
    <% } %>

    <% if (product.stock_quantity > 0) { %>
      <p class="text-success mb-3"><i class="bi bi-check-circle me-1"></i>Còn hàng (<%= product.stock_quantity %> sản phẩm)</p>
      <form action="/cart/add" method="POST" class="d-flex gap-2 mb-3">
        <input type="hidden" name="product_id" value="<%= product.id %>">
        <input type="number" name="quantity" value="1" min="1" max="<%= product.stock_quantity %>"
               class="form-control" style="width:100px">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-cart-plus me-2"></i>Thêm vào giỏ
        </button>
      </form>
    <% } else { %>
      <div class="alert alert-warning">Sản phẩm tạm hết hàng</div>
    <% } %>

    <% if (product.specifications) { %>
      <div class="mt-3">
        <h6 class="fw-bold">Thông số kỹ thuật</h6>
        <table class="table table-sm table-striped">
          <tbody>
            <% let specs = {};
               try { specs = JSON.parse(product.specifications); } catch(e) {}
               Object.entries(specs).forEach(([k, v]) => { %>
              <tr>
                <td class="text-muted" style="width:40%"><%= k %></td>
                <td><strong><%= v %></strong></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<% if (product.description) { %>
  <div class="mt-4">
    <h5 class="fw-bold border-bottom pb-2">Mô tả sản phẩm</h5>
    <p><%= product.description %></p>
  </div>
<% } %>

<div class="mt-4">
  <h5 class="fw-bold border-bottom pb-2">Đánh giá (<%= product.review_count %>)</h5>
  <% if (product.reviews && product.reviews.length > 0) { %>
    <% product.reviews.forEach(review => { %>
      <div class="border-bottom py-3">
        <div class="d-flex align-items-center gap-2 mb-1">
          <strong><%= review.full_name %></strong>
          <span class="text-warning">
            <% for(let i=1; i<=5; i++) { %>
              <i class="bi bi-star<%= i <= review.rating ? '-fill' : '' %>"></i>
            <% } %>
          </span>
          <small class="text-muted"><%= new Date(review.created_at).toLocaleDateString('vi-VN') %></small>
        </div>
        <p class="mb-0"><%= review.comment || '' %></p>
      </div>
    <% }); %>
  <% } else { %>
    <p class="text-muted">Chưa có đánh giá nào.</p>
  <% } %>
</div>

<% if (product.related && product.related.length > 0) { %>
  <div class="mt-4">
    <h5 class="fw-bold border-bottom pb-2">Sản phẩm liên quan</h5>
    <div class="row row-cols-2 row-cols-md-4 g-3">
      <% product.related.forEach(rel => { %>
        <div class="col"><%- include('../../partials/product-card', { product: rel }) %></div>
      <% }); %>
    </div>
  </div>
<% } %>
<%- include('../../partials/bot') %>
