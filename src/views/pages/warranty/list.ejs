<%- include('../../partials/top') %>
<h4 class="mb-4"><i class="bi bi-shield-check me-2"></i>Yêu cầu bảo hành của tôi</h4>

<% const wColors = {pending:'warning',approved:'info',rejected:'danger',processing:'primary',completed:'success'};
   const wLabels = {pending:'Chờ duyệt',approved:'Đã duyệt',rejected:'Từ chối',processing:'Đang xử lý',completed:'Hoàn thành'};
%>

<% if (requests.length === 0) { %>
  <div class="empty-state py-5">
    <i class="bi bi-shield-x"></i>
    <p class="mt-3 text-muted">Bạn chưa có yêu cầu bảo hành nào</p>
    <a href="/orders" class="btn btn-outline-primary">Xem đơn hàng</a>
  </div>
<% } else { %>
  <% requests.forEach(r => { %>
    <div class="card mb-3 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h6 class="fw-bold mb-1"><%= r.product_name %></h6>
            <small class="text-muted">Đơn hàng #<%= r.order_code %></small>
          </div>
          <span class="badge bg-<%= wColors[r.status] || 'secondary' %>"><%= wLabels[r.status] || r.status %></span>
        </div>
        <p class="mt-2 mb-1 small"><%= r.issue_description %></p>
        <% if (r.admin_note) { %>
          <div class="alert alert-info py-1 px-2 mt-2 mb-0 small">
            <strong>Phản hồi từ shop:</strong> <%= r.admin_note %>
          </div>
        <% } %>
        <small class="text-muted">Ngày gửi: <%= new Date(r.created_at).toLocaleDateString('vi-VN') %></small>
      </div>
    </div>
  <% }); %>
<% } %>
<%- include('../../partials/bot') %>
