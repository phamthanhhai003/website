<%- include('../../partials/top') %>
<h4 class="mb-4"><i class="bi bi-bag me-2"></i>Đơn hàng của tôi</h4>

<% if (orders.length === 0) { %>
  <div class="empty-state py-5">
    <i class="bi bi-bag-x"></i>
    <p class="mt-3 text-muted">Bạn chưa có đơn hàng nào</p>
    <a href="/products" class="btn btn-primary">Mua sắm ngay</a>
  </div>
<% } else { %>
  <% orders.forEach(order => {
       const statusColors = {pending:'warning',confirmed:'info',processing:'primary',shipping:'primary',completed:'success',cancelled:'danger'};
       const statusLabels = {pending:'Chờ xác nhận',confirmed:'Đã xác nhận',processing:'Đang chuẩn bị',shipping:'Đang giao',completed:'Hoàn thành',cancelled:'Đã hủy'};
  %>
    <div class="card mb-3 border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
          <div>
            <span class="fw-bold">#<%= order.order_code %></span>
            <span class="text-muted small ms-2">
              <%= new Date(order.created_at).toLocaleDateString('vi-VN') %>
            </span>
          </div>
          <span class="badge bg-<%= statusColors[order.order_status] || 'secondary' %>">
            <%= statusLabels[order.order_status] || order.order_status %>
          </span>
        </div>
        <div class="mt-2 d-flex justify-content-between align-items-center">
          <span class="text-muted small"><%= order.item_count %> sản phẩm</span>
          <strong class="text-danger"><%= Number(order.total_amount).toLocaleString('vi-VN') %>đ</strong>
        </div>
        <a href="/orders/<%= order.order_code %>" class="btn btn-outline-primary btn-sm mt-2">
          Xem chi tiết
        </a>
      </div>
    </div>
  <% }); %>
<% } %>
<%- include('../../partials/bot') %>
