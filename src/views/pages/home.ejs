<%- include('../partials/top') %>
<div class="p-4 p-md-5 text-center bg-dark text-white rounded-3 mb-4"
     style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%) !important">
  <h1 class="display-5 fw-bold">
    <i class="bi bi-lightning-charge-fill text-warning"></i> ElectroShop
  </h1>
  <p class="col-md-8 mx-auto fs-5 text-light">Đồ điện tử chính hãng — Giá tốt nhất thị trường</p>
  <a href="/products" class="btn btn-warning btn-lg px-4 mt-2">
    <i class="bi bi-grid me-2"></i>Khám phá sản phẩm
  </a>
</div>

<div class="mb-5">
  <h5 class="fw-bold mb-3">Danh mục nổi bật</h5>
  <div class="row g-3">
    <% if (typeof categories !== 'undefined') {
       const catIcons = {
         'dien-thoai-phu-kien': 'bi-phone',
         'laptop-may-tinh-bang': 'bi-laptop',
         'am-thanh-tai-nghe': 'bi-headphones',
         'tv-man-hinh': 'bi-tv',
         'gaming-console': 'bi-controller',
         'thiet-bi-deo-thong-minh': 'bi-smartwatch',
         'may-anh-quay-phim': 'bi-camera',
         'thiet-bi-mang-luu-tru': 'bi-wifi'
       };
       const catColors = ['text-primary','text-success','text-warning','text-info','text-danger','text-secondary','text-dark','text-primary'];
       categories.slice(0, 8).forEach((cat, i) => { %>
      <div class="col-6 col-md-3">
        <a href="/categories/<%= cat.slug %>" class="card text-center text-decoration-none border-0 shadow-sm h-100 hover-lift">
          <div class="card-body py-3">
            <i class="bi <%= catIcons[cat.slug] || 'bi-box' %> fs-2 <%= catColors[i % catColors.length] %>"></i>
            <p class="mb-0 mt-2 small fw-medium"><%= cat.name %></p>
          </div>
        </a>
      </div>
    <% }); } %>
  </div>
</div>

<% if (typeof onSale !== 'undefined' && onSale.length > 0) { %>
<div class="mb-5">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-tag-fill text-danger me-2"></i>Đang giảm giá</h5>
    <a href="/products?onSale=1" class="text-decoration-none small">Xem tất cả →</a>
  </div>
  <div class="row row-cols-2 row-cols-md-4 g-3">
    <% onSale.forEach(product => { %>
      <div class="col"><%- include('../partials/product-card', { product }) %></div>
    <% }); %>
  </div>
</div>
<% } %>

<% if (typeof newest !== 'undefined' && newest.length > 0) { %>
<div class="mb-5">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-stars text-warning me-2"></i>Sản phẩm mới nhất</h5>
    <a href="/products?sort=newest" class="text-decoration-none small">Xem tất cả →</a>
  </div>
  <div class="row row-cols-2 row-cols-md-4 g-3">
    <% newest.forEach(product => { %>
      <div class="col"><%- include('../partials/product-card', { product }) %></div>
    <% }); %>
  </div>
</div>
<% } %>

<% if (typeof topRated !== 'undefined' && topRated.length > 0) { %>
<div class="mb-5">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-star-fill text-warning me-2"></i>Đánh giá cao</h5>
    <a href="/products?sort=rating" class="text-decoration-none small">Xem tất cả →</a>
  </div>
  <div class="row row-cols-2 row-cols-md-4 g-3">
    <% topRated.forEach(product => { %>
      <div class="col"><%- include('../partials/product-card', { product }) %></div>
    <% }); %>
  </div>
</div>
<% } %>

<% if ((typeof onSale === 'undefined' || !onSale.length) && (typeof newest === 'undefined' || !newest.length)) { %>
<div class="text-center py-5 text-muted">
  <i class="bi bi-box-seam fs-1 opacity-50"></i>
  <p class="mt-3">Chưa có sản phẩm. Chạy seed.sql để thêm dữ liệu mẫu.</p>
</div>
<% } %>
<%- include('../partials/bot') %>
