<%- include('../partials/top') %>
<h4 class="mb-4"><i class="bi bi-cart3 me-2"></i>Giỏ hàng (<%= count %> sản phẩm)</h4>

<% if (items.length === 0) { %>
  <div class="empty-state py-5">
    <i class="bi bi-cart-x"></i>
    <p class="mt-3 text-muted">Giỏ hàng của bạn đang trống</p>
    <a href="/products" class="btn btn-primary">Tiếp tục mua sắm</a>
  </div>
<% } else { %>
  <div class="row">
    <div class="col-lg-8">
      <% items.forEach(item => { %>
        <div class="card mb-3 cart-item border-0 shadow-sm" id="cart-item-<%= item.id %>">
          <div class="card-body d-flex gap-3 align-items-center">
            <img src="<%= item.main_image || '/images/no-image.png' %>"
                 width="80" height="80" style="object-fit:contain" class="rounded border" alt="">
            <div class="flex-grow-1">
              <a href="/products/<%= item.slug %>" class="fw-semibold text-decoration-none text-dark">
                <%= item.name %>
              </a>
              <div class="text-danger mt-1 small"><%= Number(item.price_at_time).toLocaleString('vi-VN') %>đ</div>
            </div>
            <div class="d-flex align-items-center gap-1">
              <button class="btn btn-outline-secondary btn-sm qty-btn" data-action="minus" data-id="<%= item.id %>">−</button>
              <input type="number" class="form-control form-control-sm text-center qty-input"
                     style="width:60px" value="<%= item.quantity %>" min="1"
                     max="<%= item.stock_quantity %>" data-id="<%= item.id %>">
              <button class="btn btn-outline-secondary btn-sm qty-btn" data-action="plus" data-id="<%= item.id %>">+</button>
            </div>
            <div class="item-total fw-bold text-end" style="min-width:100px">
              <%= Number(item.price_at_time * item.quantity).toLocaleString('vi-VN') %>đ
            </div>
            <button class="btn btn-link text-danger p-0 remove-item" data-id="<%= item.id %>"
                    title="Xóa sản phẩm">
              <i class="bi bi-trash3"></i>
            </button>
          </div>
        </div>
      <% }); %>
    </div>

    <div class="col-lg-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="fw-bold mb-3">Tóm tắt đơn hàng</h6>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Tạm tính</span>
            <span id="subtotal"><%= Number(subtotal).toLocaleString('vi-VN') %>đ</span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Phí vận chuyển</span>
            <span id="shipping">
              <% if (shipping_fee === 0) { %>
                <span class="text-success fw-medium">Miễn phí</span>
              <% } else { %>
                <%= Number(shipping_fee).toLocaleString('vi-VN') %>đ
              <% } %>
            </span>
          </div>
          <% if (shipping_fee > 0) { %>
            <small class="text-muted d-block mb-2">
              <i class="bi bi-info-circle"></i> Miễn phí ship cho đơn ≥ 2.000.000đ
            </small>
          <% } %>
          <hr>
          <div class="d-flex justify-content-between fw-bold fs-5 mb-3">
            <span>Tổng cộng</span>
            <span class="text-danger" id="cart-total"><%= Number(total).toLocaleString('vi-VN') %>đ</span>
          </div>
          <a href="/checkout" class="btn btn-danger w-100">
            <i class="bi bi-credit-card me-2"></i>Đặt hàng ngay
          </a>
          <a href="/products" class="btn btn-outline-secondary w-100 mt-2">Tiếp tục mua sắm</a>
        </div>
      </div>
    </div>
  </div>
<% } %>

<script src="/js/cart.js"></script>
<%- include('../partials/bot') %>
